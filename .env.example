# =======================================
# Configurações do Flask
# =======================================
SECRET_KEY=mude-esta-chave-secreta-em-producao
DEBUG=True

# =======================================
# Banco de Dados (PostgreSQL)
# =======================================
DATABASE_URL=postgresql://usuario:senha@localhost:5432/intranet_db

# =======================================
# JWT
# =======================================
JWT_SECRET_KEY=mude-esta-chave-jwt-em-producao
JWT_ACCESS_TOKEN_EXPIRES_HOURS=8

# =======================================
# Seed inicial (Admin/Editor) — obrigatório em produção
# =======================================
ADMIN_SEED_PASSWORD=defina-uma-senha-forte-aqui
EDITOR_SEED_PASSWORD=defina-uma-senha-forte-aqui

# =======================================
# CORS
# =======================================
FRONTEND_URL=https://intranet.suaempresa.com

# =======================================
# Arquivos do curso (Google Drive)
# =======================================
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...@...iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}
ARQUIVOS_PASTA_RAIZ=1AbCdEfGhIjKlMnOpQrStUvWxYz012345
ARQUIVOS_ORIGIN_PERMITIDA=https://intranet.suaempresa.com
ARQUIVOS_CACHE_TTL_SEGUNDOS=300
